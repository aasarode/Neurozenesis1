<div class="blog-body">

    <!-- LIST VIEW -->
  <div class="blog-list-view" id="blogListView">

    {% set featured = collections.posts | first %}
    {% if featured %}
    <!-- FEATURED POST -->
    <div class="blog-featured reveal" onclick="location.href='/blog/{{ featured.fileSlug }}/'">
      <div class="blog-featured-image">
        {% if featured.data.image %}
        <img src="/{{ featured.data.image }}" alt="{{ featured.data.title }}" onerror="this.classList.add('blog-img-error')">
        <div class="blog-img-fallback"><svg width="48" height="48" viewBox="-72 -72 144 144" xmlns="http://www.w3.org/2000/svg"><circle cx="0" cy="0" r="62" fill="none" stroke="#c9a84c" stroke-width="1.2" opacity="0.5"/><polygon points="0,-62 13,-13 0,-7 -13,-13" fill="none" stroke="#e8c97a" stroke-width="1.5"/><polygon points="0,62 13,13 0,7 -13,13" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.65"/><polygon points="62,0 13,13 7,0 13,-13" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.65"/><polygon points="-62,0 -13,13 -7,0 -13,-13" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.65"/><circle cx="0" cy="0" r="10" fill="none" stroke="#e8c97a" stroke-width="1.5"/></svg></div>
        {% else %}
        <div class="blog-placeholder"><svg width="60" height="60" viewBox="-72 -72 144 144" xmlns="http://www.w3.org/2000/svg"><circle cx="0" cy="0" r="62" fill="none" stroke="#c9a84c" stroke-width="1.2" opacity="0.5"/><polygon points="0,-62 13,-13 0,-7 -13,-13" fill="none" stroke="#e8c97a" stroke-width="1.5"/><circle cx="0" cy="0" r="10" fill="none" stroke="#e8c97a" stroke-width="1.5"/></svg></div>
        {% endif %}
      </div>
      <div class="blog-featured-content">
        <div class="blog-tag">{{ featured.data.tag or 'Essay' }}</div>
        <h2>{{ featured.data.title }}</h2>
        {% if featured.data.pullQuote %}<div class="blog-pull-quote">"{{ featured.data.pullQuote }}"</div>{% endif %}
        <p class="blog-excerpt">{{ featured.data.excerpt or (featured.templateContent | striptags | truncate(200)) }}</p>
        <div class="blog-meta">{{ featured.date | postDate }} &middot; {{ featured.templateContent | readTime }}</div>
        <a class="blog-read-more" href="/blog/{{ featured.fileSlug }}/">Read more &rarr;</a>
      </div>
    </div>
    {% endif %}

    <!-- GRID -->
    <div class="blog-grid-label">More from the Interior</div>
    <div class="blog-grid">
    {% for post in collections.posts | slice(1) %}
      <div class="blog-card reveal">
        <a href="/blog/{{ post.fileSlug }}/" style="text-decoration:none;color:inherit;">
        <div class="blog-card-image">
          {% if post.data.image %}
          <img src="/{{ post.data.image }}" alt="{{ post.data.title }}" onerror="this.classList.add('blog-img-error')">
          <div class="blog-img-fallback"><svg width="40" height="40" viewBox="-72 -72 144 144" xmlns="http://www.w3.org/2000/svg"><polygon points="0,-62 13,-13 0,-7 -13,-13" fill="none" stroke="#e8c97a" stroke-width="1.5"/><polygon points="0,62 13,13 0,7 -13,13" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.65"/><polygon points="62,0 13,13 7,0 13,-13" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.65"/><polygon points="-62,0 -13,13 -7,0 -13,-13" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.65"/></svg></div>
          {% else %}
          <div class="blog-placeholder"><svg width="40" height="40" viewBox="-72 -72 144 144" xmlns="http://www.w3.org/2000/svg"><polygon points="0,-62 13,-13 0,-7 -13,-13" fill="none" stroke="#e8c97a" stroke-width="1.5"/><circle cx="0" cy="0" r="10" fill="none" stroke="#e8c97a" stroke-width="1.5"/></svg></div>
          {% endif %}
        </div>
        <div class="blog-tag">{{ post.data.tag or 'Essay' }}</div>
        <h3>{{ post.data.title }}</h3>
        {% if post.data.pullQuote %}<div class="blog-pull-quote">"{{ post.data.pullQuote }}"</div>{% endif %}
        <p class="blog-excerpt">{{ post.data.excerpt or (post.templateContent | striptags | truncate(150)) }}</p>
        <div class="blog-meta">{{ post.date | postDate }} &middot; {{ post.templateContent | readTime }}</div>
        </a>
      </div>
    {% endfor %}
    </div>

  </div><!-- end blog-list-view -->

  <!-- FULL POST VIEW -->
  <div class="blog-post-view" id="blogPostView">
    <button class="blog-back" onclick="closePost()">← Back to the Interior</button>
