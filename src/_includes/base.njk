<style>
:root {
  --midnight: #080b12;
  --deep: #0d1220;
  --navy: #111827;
  --gold: #c9a84c;
  --gold-light: #e8c97a;
  --gold-dim: #8a6f2e;
  --bone: #f0ead8;
  --ivory: #e8e0cc;
  --glow: rgba(201,168,76,0.15);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--midnight);
  color: var(--ivory);
  font-family: 'Jost', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
  cursor: none;
}

.cursor {
  width: 8px; height: 8px;
  background: var(--gold);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s;
}
.cursor-ring {
  width: 32px; height: 32px;
  border: 1px solid rgba(201,168,76,0.35);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 999;
  opacity: 0.3;
  mix-blend-mode: overlay;
}

.stars {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.star {
  position: absolute;
  background: var(--gold-light);
  border-radius: 50%;
  animation: twinkle var(--d) ease-in-out infinite;
  opacity: 0;
}
@keyframes twinkle {
  0%, 100% { opacity: 0; }
  50% { opacity: var(--o); }
}

/* NAV */
nav {
  position: fixed;
  top: 0; width: 100%;
  padding: 2rem 5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  background: linear-gradient(to bottom, rgba(8,11,18,0.9) 0%, transparent 100%);
}

.nav-logo {
  font-family: 'Cinzel', serif;
  font-size: 1rem;
  letter-spacing: 0.45em;
  color: var(--gold);
  text-decoration: none;
  text-transform: uppercase;
  cursor: none;
}

.nav-links {
  display: flex;
  gap: 1.8rem;
  list-style: none;
  align-items: center;
}

.nav-links a {
  color: var(--ivory);
  text-decoration: none;
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.5;
  transition: opacity 0.3s, color 0.3s;
  cursor: none;
}
.nav-links a:hover { opacity: 1; color: var(--gold); }

.nav-reach {
  padding: 0.55rem 1.6rem;
  border: 1px solid rgba(201,168,76,0.3);
  color: var(--gold) !important;
  opacity: 1 !important;
}
.nav-reach:hover { background: var(--glow); border-color: var(--gold) !important; }

/* PAGE SYSTEM */
.page { display: block; }
.page.active { display: block; }

section { position: relative; z-index: 1; }

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes breathe {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
}
@keyframes moonGlow {
  0%, 100% { text-shadow: 0 0 20px rgba(201,168,76,0.3); }
  50% { text-shadow: 0 0 50px rgba(201,168,76,0.8), 0 0 100px rgba(201,168,76,0.3); }
}
@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.9s ease, transform 0.9s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* SHARED ELEMENTS */
.section-label {
  font-size: 0.62rem;
  letter-spacing: 0.45em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
}

.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  font-weight: 300;
  line-height: 1.15;
  color: var(--bone);
}
.section-title em {
  font-style: italic;
  color: var(--gold-light);
}

.gold-rule {
  width: 50px;
  height: 1px;
  background: linear-gradient(to right, var(--gold), transparent);
  margin: 1.5rem 0;
}

.soft-link {
  display: inline-block;
  font-size: 0.68rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold-dim);
  text-decoration: none;
  cursor: none;
  transition: color 0.3s;
  border-bottom: 1px solid rgba(201,168,76,0.2);
  padding-bottom: 0.2rem;
}
.soft-link:hover { color: var(--gold); border-color: var(--gold); }

.btn-outline {
  display: inline-block;
  padding: 0.85rem 2.2rem;
  border: 1px solid rgba(201,168,76,0.3);
  color: var(--gold);
  font-size: 0.68rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  text-decoration: none;
  cursor: none;
  transition: background 0.3s, border-color 0.3s;
  font-family: 'Jost', sans-serif;
  background: transparent;
}
.btn-outline:hover { background: var(--glow); border-color: var(--gold); }

/* ===================== HOME PAGE ===================== */

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 8rem 4rem 6rem;
  overflow: hidden;
}

.hero-orb {
  position: absolute;
  width: 700px; height: 700px;
  background: radial-gradient(ellipse, rgba(201,168,76,0.05) 0%, transparent 70%);
  border-radius: 50%;
  top: 50%; left: 50%;
  animation: breathe 10s ease-in-out infinite;
}
.hero-orb-2 {
  width: 280px; height: 280px;
  background: radial-gradient(ellipse, rgba(201,168,76,0.09) 0%, transparent 70%);
  animation-delay: 5s;
}

.hero-symbol {
  font-size: 1.6rem;
  color: var(--gold);
  margin-bottom: 3rem;
  animation: fadeUp 1.2s ease forwards;
  opacity: 0;
  letter-spacing: 0.6em;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3.5rem, 8vw, 7rem);
  font-weight: 300;
  letter-spacing: 0.04em;
  line-height: 1.05;
  animation: fadeUp 1.2s 0.35s ease forwards;
  opacity: 0;
  color: var(--bone);
}
.hero h1 em {
  font-style: italic;
  color: var(--gold);
  display: block;
}

.hero-sub {
  margin-top: 2.5rem;
  font-size: 0.78rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--gold-dim);
  animation: fadeUp 1.2s 0.65s ease forwards;
  opacity: 0;
}

.hero-divider {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  margin: 3rem auto;
  animation: fadeUp 1.2s 0.9s ease forwards;
  opacity: 0;
}

.hero-opening {
  max-width: 520px;
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.1rem, 1.8vw, 1.4rem);
  line-height: 1.85;
  color: rgba(232,224,204,0.75);
  animation: fadeUp 1.2s 1.1s ease forwards;
  opacity: 0;
}

.hero-scroll {
  position: absolute;
  bottom: 3rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  animation: fadeUp 1.2s 1.5s ease forwards;
  opacity: 0;
}
.hero-scroll span {
  font-size: 0.58rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--gold-dim);
}
.scroll-line {
  width: 1px; height: 45px;
  background: linear-gradient(to bottom, var(--gold-dim), transparent);
  animation: scrollPulse 2.5s ease-in-out infinite;
}

/* OPENING PHILOSOPHY */
.philosophy {
  padding: 10rem 5rem;
  max-width: 1000px;
  margin: 0 auto;
  text-align: center;
}

.philosophy-question {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  font-weight: 300;
  color: var(--bone);
  line-height: 1.6;
  margin-bottom: 4rem;
}

.philosophy-question em {
  color: var(--gold-light);
  font-style: normal;
}

.philosophy-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  text-align: left;
  margin-top: 5rem;
}

.philosophy-body p {
  font-size: 1rem;
  line-height: 2;
  color: rgba(232,224,204,0.68);
}

.philosophy-divider {
  width: 1px;
  background: linear-gradient(to bottom, transparent, rgba(201,168,76,0.2), transparent);
  display: block;
}

/* THE APPROACH */
.approach {
  padding: 8rem 5rem;
  background: var(--deep);
  position: relative;
  overflow: hidden;
}

.approach::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 100% 50%, rgba(201,168,76,0.04) 0%, transparent 60%);
}

.approach-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 8rem;
  align-items: start;
  position: relative;
  z-index: 1;
}

.approach-label {
  position: sticky;
  top: 8rem;
}

.approach-threads {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.thread {
  padding: 3rem 0;
  border-bottom: 1px solid rgba(201,168,76,0.08);
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 3rem;
  align-items: start;
}

.thread:first-child { border-top: 1px solid rgba(201,168,76,0.08); }

.thread-number {
  font-family: 'Cinzel', serif;
  font-size: 0.55rem;
  letter-spacing: 0.3em;
  color: rgba(201,168,76,0.4);
  padding-top: 0.4rem;
  min-width: 3rem;
}

.thread-content h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.7rem;
  font-weight: 400;
  color: var(--bone);
  margin-bottom: 1rem;
  line-height: 1.2;
}

.thread-link {
  color: var(--bone);
  text-decoration: none;
  cursor: none;
  transition: color 0.3s;
  border-bottom: 1px solid transparent;
  padding-bottom: 0.1rem;
}
.thread-link:hover {
  color: var(--gold-light);
  border-bottom-color: rgba(201,168,76,0.3);
}

.thread-content p {
  font-size: 0.9rem;
  line-height: 1.95;
  color: rgba(232,224,204,0.6);
}

/* ABOUT */
.about {
  padding: 10rem 5rem;
  max-width: 1300px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rem;
  align-items: center;
}

.about-text p {
  font-size: 1rem;
  line-height: 2;
  color: rgba(232,224,204,0.72);
  margin-bottom: 1.5rem;
}

.about-credentials {
  margin-top: 3rem;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.credential {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  color: var(--gold-dim);
  text-transform: uppercase;
}
.credential::before {
  content: '';
  width: 16px; height: 1px;
  background: var(--gold);
  flex-shrink: 0;
}

.about-portrait {
  position: relative;
  aspect-ratio: 3/4;
  background: linear-gradient(135deg, var(--deep) 0%, var(--navy) 100%);
  border: 1px solid rgba(201,168,76,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.about-portrait::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 30% 30%, rgba(201,168,76,0.1) 0%, transparent 60%);
  z-index: 1;
  pointer-events: none;
}
.about-portrait img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.about-portrait-corner {
  position: absolute;
  width: 28px; height: 28px;
  border-color: rgba(201,168,76,0.3);
  border-style: solid;
  z-index: 2;
}
.corner-tl { top: 1rem; left: 1rem; border-width: 1px 0 0 1px; }
.corner-br { bottom: 1rem; right: 1rem; border-width: 0 1px 1px 0; }

/* THE HEALER'S VOW */
.vow-section {
  padding: 10rem 5rem;
  background: var(--deep);
  position: relative;
  overflow: hidden;
}
.vow-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 50%, rgba(201,168,76,0.04) 0%, transparent 70%);
}
.vow-corners {
  position: absolute;
  inset: 3rem;
  pointer-events: none;
}
.vc { position: absolute; width: 36px; height: 36px; border-color: rgba(201,168,76,0.18); border-style: solid; }
.vc-tl { top: 0; left: 0; border-width: 1px 0 0 1px; }
.vc-tr { top: 0; right: 0; border-width: 1px 1px 0 0; }
.vc-bl { bottom: 0; left: 0; border-width: 0 0 1px 1px; }
.vc-br { bottom: 0; right: 0; border-width: 0 1px 1px 0; }

.vow-inner {
  max-width: 680px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  z-index: 1;
}
.vow-title {
  font-family: 'Cinzel', serif;
  font-size: 0.72rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 3rem;
}
.vow-poem {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.1rem, 1.8vw, 1.45rem);
  line-height: 2.1;
  color: var(--ivory);
}
.vow-poem::before, .vow-poem::after {
  content: '';
  display: block;
  width: 100%;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(201,168,76,0.25), transparent);
  margin: 2.5rem 0;
}
.vow-poem .emphasis { color: var(--gold-light); font-weight: 400; }
.vow-poem .stanza { display: block; margin-bottom: 0.2rem; }
.vow-attribution {
  margin-top: 3rem;
  font-size: 0.68rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold-dim);
}

/* ===================== OFFERINGS PAGE ===================== */

.offerings-hero {
  min-height: 50vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 10rem 4rem 5rem;
  overflow: hidden;
}

.offerings-hero .hero-orb { opacity: 0.4; }

.offerings-intro {
  padding: 6rem 5rem;
  max-width: 820px;
  margin: 0 auto;
  text-align: center;
}

.offerings-intro p {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.1rem, 1.8vw, 1.5rem);
  line-height: 1.9;
  color: rgba(232,224,204,0.72);
  margin-bottom: 1.5rem;
}

/* OFFERING ENTRY */
.offering-entry {
  padding: 8rem 5rem;
  border-top: 1px solid rgba(201,168,76,0.07);
}

.offering-entry.alt {
  background: linear-gradient(to bottom, transparent, rgba(13,18,32,0.4), transparent);
}

.offering-entry-inner {
  max-width: 1100px;
  margin: 0 auto;
}

.offering-entry-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: end;
  margin-bottom: 5rem;
}

.offering-entry-header .section-label { margin-bottom: 0.75rem; }

.offering-entry-header h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.5rem, 4.5vw, 4rem);
  font-weight: 300;
  color: var(--bone);
  line-height: 1.1;
}
.offering-entry-header h2 em {
  font-style: italic;
  color: var(--gold-light);
  display: block;
}

.offering-entry-header .offering-note {
  font-size: 0.82rem;
  line-height: 1.9;
  color: rgba(232,224,204,0.55);
  align-self: end;
}

.offering-entry-header .offering-note .investment-note {
  margin-top: 1.5rem;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  color: rgba(201,168,76,0.5);
  text-transform: uppercase;
  border-top: 1px solid rgba(201,168,76,0.12);
  padding-top: 1rem;
}

.offering-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
}

.offering-body p {
  font-size: 0.95rem;
  line-height: 2;
  color: rgba(232,224,204,0.65);
  margin-bottom: 1.2rem;
}

.offering-threads {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.offering-thread {
  padding: 1.5rem 0;
  border-bottom: 1px solid rgba(201,168,76,0.07);
}
.offering-thread:first-child { border-top: 1px solid rgba(201,168,76,0.07); }

.offering-thread-q {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 1rem;
  color: var(--bone);
  margin-bottom: 0.4rem;
}

.offering-thread-a {
  font-size: 0.8rem;
  line-height: 1.8;
  color: rgba(232,224,204,0.5);
}

/* MOON ICON */
.moon-icon {
  display: block;
  font-size: 2.5rem;
  margin-bottom: 1.5rem;
  animation: moonGlow 5s ease-in-out infinite;
}

/* COMING THROUGH BAND */
.coming-through {
  padding: 6rem 5rem;
  text-align: center;
  background: var(--deep);
  border-top: 1px solid rgba(201,168,76,0.07);
  border-bottom: 1px solid rgba(201,168,76,0.07);
}

.coming-through p {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.1rem, 1.8vw, 1.6rem);
  color: rgba(232,224,204,0.6);
  max-width: 700px;
  margin: 0 auto;
  line-height: 1.8;
}

.coming-through .coming-label {
  font-family: 'Jost', sans-serif;
  font-style: normal;
  font-size: 0.62rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--gold-dim);
  display: block;
  margin-bottom: 1.5rem;
}

/* ===================== CONVERSATION PAGE ===================== */

.conversation-hero {
  min-height: 45vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 10rem 4rem 4rem;
  overflow: hidden;
}

.conversation-hero .hero-orb { opacity: 0.35; }

.conversation-body {
  padding: 4rem 5rem 10rem;
  max-width: 900px;
  margin: 0 auto;
}

.conversation-preamble {
  text-align: center;
  margin-bottom: 6rem;
}

.conversation-preamble p {
  font-size: 1rem;
  line-height: 2;
  color: rgba(232,224,204,0.65);
  margin-bottom: 1rem;
  max-width: 620px;
  margin-left: auto;
  margin-right: auto;
}

.conversation-paths {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin-bottom: 6rem;
}

.convo-path {
  padding: 3rem 2.5rem;
  background: rgba(13,18,32,0.5);
  border: 1px solid rgba(201,168,76,0.09);
