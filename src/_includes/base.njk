    '<div class="blog-post-pull">' + post.pullQuote + '</div>' +
    '<div class="blog-post-body">' + post.body + '</div>';
  document.documentElement.scrollTop = 0;
  document.body.scrollTop = 0;
}

function closePost() {
  document.getElementById('blogPostView').classList.remove('active');
  document.getElementById('blogListView').classList.remove('hidden');
  document.documentElement.scrollTop = 0;
  document.body.scrollTop = 0;
}
</script>

</script>
