<div id="waitlistModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; align-items:center; justify-content:center;">
  <div style="background:#0d1117; border:1px solid rgba(201,168,76,0.3); padding:3rem; max-width:480px; width:90%; position:relative;">
    <button onclick="closeWaitlist()" style="position:absolute; top:1rem; right:1.5rem; background:none; border:none; color:rgba(232,224,204,0.5); font-size:1.5rem; cursor:pointer;">×</button>
    <div style="font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.15em; color:var(--gold); margin-bottom:0.5rem;">JOIN THE LIST</div>
    <h3 style="font-family:'Cormorant Garamond',serif; font-size:1.8rem; color:var(--bone); font-weight:300; margin-bottom:0.5rem;">Workshops &amp; Intensives</h3>
    <p id="waitlistOfferingLabel" style="font-size:0.85rem; color:rgba(232,224,204,0.55); margin-bottom:2rem;">Be notified when dates are announced.</p>
    <input type="hidden" id="waitlistOffering" value="">
    <div style="display:flex; flex-direction:column; gap:1rem;">
      <input id="waitlistName" type="text" placeholder="Your Name" style="background:rgba(255,255,255,0.04); border:1px solid rgba(201,168,76,0.25); padding:0.85rem 1rem; color:var(--bone); font-family:'Jost',sans-serif; font-size:0.9rem; width:100%; box-sizing:border-box;">
      <input id="waitlistEmail" type="email" placeholder="Your Email" style="background:rgba(255,255,255,0.04); border:1px solid rgba(201,168,76,0.25); padding:0.85rem 1rem; color:var(--bone); font-family:'Jost',sans-serif; font-size:0.9rem; width:100%; box-sizing:border-box;">
      <button id="waitlistSubmit" style="background:none; border:1px solid rgba(201,168,76,0.5); color:var(--gold); font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.15em; padding:1rem; cursor:pointer; margin-top:0.5rem;">Join the List</button>
    </div>
  </div>
</div>
<script>
// CURSOR
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mx = 0, my = 0, rx = 0, ry = 0;
let rafId = null;

function animateRing() {
  const dx = mx - rx;
  const dy = my - ry;
  rx += dx * 0.18;
  ry += dy * 0.18;
  ring.style.left = rx + 'px';
  ring.style.top = ry + 'px';
  // Stop the loop once the ring is close enough to the cursor
  if (Math.abs(dx) > 0.1 || Math.abs(dy) > 0.1) {
    rafId = requestAnimationFrame(animateRing);
  } else {
    rafId = null;
  }
}

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx + 'px';
  cursor.style.top = my + 'px';
  // Only start the loop if it isn't already running
  if (!rafId) {
    rafId = requestAnimationFrame(animateRing);
  }
});

document.addEventListener('mouseover', e => {
  if (e.target.closest('a, button, .service-card, .convo-path, .offering-thread, .thread')) {
    cursor.style.width = '12px'; cursor.style.height = '12px';
    ring.style.width = '50px'; ring.style.height = '50px';
  }
});
document.addEventListener('mouseout', e => {
  if (e.target.closest('a, button, .service-card, .convo-path, .offering-thread, .thread')) {
    cursor.style.width = '8px'; cursor.style.height = '8px';
    ring.style.width = '32px'; ring.style.height = '32px';
  }
});

// STARS
const starsEl = document.getElementById('stars');
for (let i = 0; i < 130; i++) {
  const s = document.createElement('div');
  s.className = 'star';
  s.style.left = Math.random() * 100 + '%';
  s.style.top = Math.random() * 100 + '%';
  const sz = Math.random() * 2 + 0.5;
  s.style.width = sz + 'px'; s.style.height = sz + 'px';
  s.style.setProperty('--d', (Math.random() * 4 + 2) + 's');
  s.style.setProperty('--o', Math.random() * 0.55 + 0.1);
  s.style.animationDelay = Math.random() * 6 + 's';
  starsEl.appendChild(s);
}

// SCROLL REVEAL
function initReveal() {
  const els = document.querySelectorAll('.reveal:not(.visible)');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), 80);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  els.forEach(el => obs.observe(el));
}
initReveal();

// CONVERSATION FORM — Formspree
var fsEl = document.getElementById('formSubmit');
if (fsEl) { fsEl.addEventListener('click', async function(e) {
  e.preventDefault();
  const btn = this;
  const nameVal  = document.getElementById('convName').value.trim();
  const emailVal = document.getElementById('convEmail').value.trim();
  const topicVal = document.getElementById('convTopic').value;
  const msgVal   = document.getElementById('convMessage').value.trim();

  if (!nameVal || !emailVal) {
    btn.textContent = 'Name & email required';
    btn.style.borderColor = 'rgba(201,168,76,0.6)';
    setTimeout(() => { btn.textContent = 'Send'; btn.style.borderColor = ''; }, 3000);
    return;
  }

  btn.textContent = 'Sending…';
  btn.disabled = true;

  const data = new FormData();
  data.append('name', nameVal);
  data.append('email', emailVal);
  data.append('interest', topicVal);
  data.append('message', msgVal);

  try {
    const res = await fetch('https://formspree.io/f/xreyvdyg', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: data
    });
    const json = await res.json();
    if (res.ok) {
      btn.textContent = 'Received ✦';
      btn.style.borderColor = 'var(--gold)';
      btn.style.color = 'var(--gold-light)';
      document.getElementById('convName').value = '';
      document.getElementById('convEmail').value = '';
      document.getElementById('convTopic').value = '';
      document.getElementById('convMessage').value = '';
    } else {
      const errMsg = json.errors ? json.errors.map(e => e.message).join(', ') : 'Submission failed';
      btn.textContent = errMsg;
    }
  } catch(err) {
    btn.textContent = 'Network error — check connection';
  } finally {
    btn.disabled = false;
    setTimeout(() => {
      btn.textContent = 'Send';
      btn.style.borderColor = '';
      btn.style.color = '';
    }, 5000);
  }
}); }

// WAITLIST MODAL
function openWaitlist(offering) {
  document.getElementById('waitlistOffering').value = offering || '';
  document.getElementById('waitlistOfferingLabel').textContent = offering || 'Workshops & Intensives';
  document.getElementById('waitlistModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeWaitlist() {
  document.getElementById('waitlistModal').classList.remove('open');
  document.body.style.overflow = '';
}
var wModalEl = document.getElementById('waitlistModal');
if (wModalEl) { wModalEl.addEventListener('click', function(e) {
  if (e.target === this) closeWaitlist();
}); }

// Modal open/close display toggling
var wModal2 = document.getElementById('waitlistModal');
if (wModal2) { var wObserver = new MutationObserver(function() {
  wModal2.style.display = wModal2.classList.contains('open') ? 'flex' : 'none';
}); wObserver.observe(wModal2, { attributes: true, attributeFilter: ['class'] }); }

var wsEl = document.getElementById('waitlistSubmit');
if (wsEl) { wsEl.addEventListener('click', async function(e) {
  e.preventDefault();
  const btn = this;
  const nameVal  = document.getElementById('waitlistName').value.trim();
  const emailVal = document.getElementById('waitlistEmail').value.trim();
  const offering = document.getElementById('waitlistOffering').value;

  if (!nameVal || !emailVal) {
    btn.textContent = 'Name & email required';
    setTimeout(() => { btn.textContent = 'Join the List'; }, 3000);
    return;
  }

  btn.textContent = 'Sending...';
  btn.disabled = true;

  const data = new FormData();
  data.append('name', nameVal);
  data.append('email', emailVal);
  data.append('interest', 'Waitlist: ' + offering);
  data.append('message', 'Please add me to the waitlist.');

  try {
    const res = await fetch('https://formspree.io/f/xreyvdyg', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: data
    });
    const json = await res.json();
    if (res.ok) {
      btn.textContent = 'You are on the list';
      btn.style.borderColor = 'var(--gold)';
      btn.style.color = 'var(--gold-light)';
      document.getElementById('waitlistName').value = '';
      document.getElementById('waitlistEmail').value = '';
      setTimeout(function() { closeWaitlist(); }, 2500);
    } else {
      const msg = json.errors ? json.errors.map(function(e) { return e.message; }).join(', ') : 'Submission failed';
      btn.textContent = msg;
    }
  } catch(err) {
    btn.textContent = 'Network error - check connection';
  } finally {
    btn.disabled = false;
    setTimeout(function() {
      btn.textContent = 'Join the List';
      btn.style.borderColor = '';
      btn.style.color = '';
    }, 5000);
  }
});
}

</script>
</body>
</html>
