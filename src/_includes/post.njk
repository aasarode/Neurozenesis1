---
layout: base.njk
---
<script>document.addEventListener("DOMContentLoaded",function(){document.querySelectorAll(".page").forEach(function(p){p.style.display="block";});});</script>

<div class="page active" id="page-blog">
<div class="blog-body">
  <div class="blog-post-view active" style="display:block;">
    <button class="blog-back" onclick="history.back()">&#8592; Back to the Interior</button>
    {% if image %}
    <img class="blog-post-image" src="{{ image }}" alt="{{ title }}">
    {% endif %}
    <div class="blog-tag">{{ tag or 'Essay' }}</div>
    <h1 class="blog-post-title">{{ title }}</h1>
    <div class="blog-post-meta">{{ page.date | postDate }} &nbsp;&middot;&nbsp; {{ content | readTime }}</div>
    {% if pullQuote %}
    <div class="blog-post-pull">{{ pullQuote }}</div>
    {% endif %}
    <div class="blog-post-body">
      {{ content | safe }}
    </div>
  </div>
</div>

